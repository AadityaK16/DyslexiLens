# ─────────────────────────────────────────────
# DyslexiLens – Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in your K2 API key below
# 3. Never commit .env.local to git
# ─────────────────────────────────────────────

# Get your K2 key from: https://api.k2think.ai
# The variable is named GEMINI_API_KEY for backwards compatibility
GEMINI_API_KEY=your_k2_api_key_here
